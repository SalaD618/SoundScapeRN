{
  "expo": {
    "name": "SoundScape",
    "slug": "soundscape-react-native-ts",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.example.soundscapern",
      "permissions": [
        "INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-font"
    ]
  }
}
